# ── Multimodal Search Pipeline — Environment Variables ──────────────────────
# No API keys are required. All models run locally.

# Optional: override Tesseract executable path (Windows users)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional: override ChromaDB storage directory (default: ./chroma_db)
# CHROMA_DIR=./chroma_db

# Optional: set Whisper model size (tiny | base | small | medium | large)
# WHISPER_MODEL=base

# Required for Extension 1 video segment summarization (Claude API)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override ffmpeg executable path (Windows users)
# Required if ffmpeg is not on your system PATH.
# Download from https://ffmpeg.org/download.html, then point this at the binary.
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
